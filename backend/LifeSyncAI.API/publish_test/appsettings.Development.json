    "Issuer": "LifeSyncAI_API",
    "Audience": "LifeSyncAI_Client",
    "ExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "SmtpSettings": {
    "Host": "smtp.gmail.com",
    "Port": "587",
